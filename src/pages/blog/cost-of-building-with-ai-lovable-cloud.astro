---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import BlogDetailsHero from "../../components/BlogDetailsHero.astro";
import BlogProse from "../../components/BlogProse.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import Contact from "../../components/Contact.astro";
import FAQ from "../../components/FAQ.astro";
import Footer from "../../components/Footer.astro";

const post = {
  id: "cost-of-building-with-ai-lovable-cloud",
  data: {
    title: "The Cost of Building with AI: Decoding Lovable Cloud Pricing",
    excerpt: "Building with AI is faster, but is it cheaper? We break down the real-world costs of Lovable Cloud and how to budget for your next build sprint.",
    publishDate: "2026-05-18",
    image: "https://images.pexels.com/photos/3183150/pexels-photo-3183150.jpeg",
    author: {
      name: "Ahmed Zulfiqar",
      image: "https://images.pexels.com/photos/1181671/pexels-photo-1181671.jpeg",
    },
  },
};
---

<Layout
  title={`${post.data.title} | ValidMVPs`}
  description={post.data.excerpt}
  ogType="article"
>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />
    <BlogDetailsHero
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      featuredImage={post.data.image}
    />
    <BlogProse>
      <div class="flex flex-col items-center gap-10 md:gap-20 w-full mx-auto text-[#0D1B15]">
        <div class="w-full">
          <div class="bg-white p-8 rounded-[20px] shadow-sm mb-12 border border-[#0D1B15]/5">
            <h3 class="font-['Bricolage_Grotesque'] font-medium text-2xl mb-4">Cost Breakdown</h3>
            <ul class="space-y-2 text-lg font-inter">
              <li>💰 <strong>Usage-Based Billing:</strong> Understanding tokens vs. compute cycles.</li>
              <li>🚀 <strong>The MVP Budget:</strong> How much to allocate for a 30-day build sprint.</li>
              <li>📈 <strong>Scaling Costs:</strong> What happens when your traffic spikes?</li>
            </ul>
          </div>
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">The AI Tax or the Speed Dividend?</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] mb-8 font-inter">
            In 2026, the question isn't whether AI can build your app, but whether you can afford to let it. Lovable Cloud offers unprecedented speed, but its usage-based pricing model can be a shock to founders accustomed to flat-rate hosting. This guide demystifies the costs of building with AI, helping you understand when the "speed dividend" outweighs the "AI tax."
          </p>
        </div>
      </div>
    </BlogProse>
    <RelatedPosts currentSlug={post.id} />
    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
