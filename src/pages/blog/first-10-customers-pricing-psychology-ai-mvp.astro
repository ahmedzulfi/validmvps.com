---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import BlogDetailsHero from "../../components/BlogDetailsHero.astro";
import BlogProse from "../../components/BlogProse.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import Contact from "../../components/Contact.astro";
import FAQ from "../../components/FAQ.astro";
import Footer from "../../components/Footer.astro";

const post = {
  id: "first-10-customers-pricing-psychology-ai-mvp",
  data: {
    title: "First 10 Customers: Pricing Psychology for AI-First Startups",
    excerpt: "Should you give early adopters a discount? How do you price an AI-built MVP? We explore the psychology of early customer acquisition in the age of AI.",
    publishDate: "2026-05-20",
    image: "https://images.pexels.com/photos/3183191/pexels-photo-3183191.jpeg",
    author: {
      name: "Ahmed Zulfiqar",
      image: "https://images.pexels.com/photos/1181671/pexels-photo-1181671.jpeg",
    },
  },
};
---

<Layout
  title={`${post.data.title} | ValidMVPs`}
  description={post.data.excerpt}
  ogType="article"
>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />
    <BlogDetailsHero
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      featuredImage={post.data.image}
    />
    <BlogProse>
      <div class="flex flex-col items-center gap-10 md:gap-20 w-full mx-auto text-[#0D1B15]">
        <div class="w-full">
          <div class="bg-white p-8 rounded-[20px] shadow-sm mb-12 border border-[#0D1B15]/5">
            <h3 class="font-['Bricolage_Grotesque'] font-medium text-2xl mb-4">Pricing Strategies</h3>
            <ul class="space-y-2 text-lg font-inter">
              <li>💎 <strong>Value vs. Speed:</strong> Pricing your MVP based on the problem solved, not the build time.</li>
              <li>⏳ <strong>Discount Psychology:</strong> When (and how) to offer lifetime deals to early believers.</li>
              <li>🤝 <strong>Customer Feedback:</strong> Trading lower prices for deep product insights.</li>
            </ul>
          </div>
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">The "AI is Free" Trap</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] mb-8 font-inter">
            In 2026, many customers assume that because you built your app with AI, it should be cheap—or even free. This is the "AI is Free" trap. Your first 10 customers are crucial not just for revenue, but for setting the psychological anchor of your product's value. This guide explores how to navigate pricing conversations with early adopters to ensure you're building a sustainable business, not just a hobby.
          </p>
        </div>
      </div>
    </BlogProse>
    <RelatedPosts currentSlug={post.id} />
    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
