---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import BlogDetailsHero from "../../components/BlogDetailsHero.astro";
import BlogProse from "../../components/BlogProse.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import Contact from "../../components/Contact.astro";
import FAQ from "../../components/FAQ.astro";
import Footer from "../../components/Footer.astro";

const post = {
  id: "wrapping-lovable-capacitor-guide",
  data: {
    title: "Wrapping Lovable with Capacitor: A Step-by-Step Tutorial",
    excerpt: "Learn how to take your Lovable web app and turn it into a native iOS and Android application using Capacitor.",
    publishDate: "2026-05-16",
    image: "https://images.pexels.com/photos/1181671/pexels-photo-1181671.jpeg",
    author: {
      name: "Ahmed Zulfiqar",
      image: "https://images.pexels.com/photos/1181671/pexels-photo-1181671.jpeg",
    },
  },
};
---

<Layout
  title={`${post.data.title} | ValidMVPs`}
  description={post.data.excerpt}
  ogType="article"
>
  <div class="flex flex-col min-h-screen bg-[#F6F7FF]">
    <Navbar />
    <BlogDetailsHero
      title={post.data.title}
      excerpt={post.data.excerpt}
      authorName={post.data.author.name}
      authorImage={post.data.author.image}
      publishDate={new Date(post.data.publishDate).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
      featuredImage={post.data.image}
    />
    <BlogProse>
      <div class="flex flex-col items-center gap-10 md:gap-20 w-full mx-auto text-[#0D1B15]">
        <div class="w-full">
          <div class="bg-white p-8 rounded-[20px] shadow-sm mb-12 border border-[#0D1B15]/5">
            <h3 class="font-['Bricolage_Grotesque'] font-medium text-2xl mb-4">Tutorial Steps</h3>
            <ul class="space-y-2 text-lg font-inter">
              <li>⚙️ <strong>Environment Setup:</strong> Configuring Capacitor in your project.</li>
              <li>📦 <strong>Build Process:</strong> Exporting from Lovable to a Capacitor-ready build.</li>
              <li>📲 <strong>Native Features:</strong> Accessing camera and push notifications.</li>
            </ul>
          </div>
          <h2 class="font-['Bricolage_Grotesque'] font-medium text-3xl md:text-[48px] tracking-[-1px] md:tracking-[-3px] leading-[1.2] mb-4 mt-8">Why Capacitor?</h2>
          <p class="text-lg md:text-[22px] leading-relaxed md:leading-[1.6em] mb-8 font-inter">
            Capacitor is the modern successor to Cordova, providing a robust bridge between web technologies and native APIs. For Lovable developers, it's the perfect tool to transform a React-based web app into a high-performance native application. This tutorial walks you through the entire process, from initial setup to running your app on an emulator.
          </p>
        </div>
      </div>
    </BlogProse>
    <RelatedPosts currentSlug={post.id} />
    <Contact />
    <FAQ />
    <Footer />
  </div>
</Layout>
